{
  "name": "graph-lens-lite",
  "version": "1.6.1",
  "main": "src/package/electron_app.js",
  "description": "Visualise and explore property graphs in a lightweight desktop app.",
  "homepage": "https://github.com/Delta4AI/GraphLensLite",
  "author": {
    "name": "Matthias Ley",
    "email": "matthias.ley@delta4.ai"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist && mkdir -p dist",
    "bundle": "esbuild src/gll.js --bundle --outfile=src/gll.bundle.js",
    "bundle:watch": "esbuild src/gll.js --bundle --outfile=src/gll.bundle.js --watch --sourcemap",
    "bundle:serve": "esbuild src/gll.js --bundle --outfile=src/gll.bundle.js --watch --sourcemap --servedir=src",
    "create-inline-html": "node src/package/inline_html.mjs src/graph_lens_lite.html dist/graph-lens-lite_${npm_package_version}.html",
    "create-gll-zip": "cd src && zip -r ../dist/GLL-source-bundle_${npm_package_version}.zip gll.bundle.js graph_lens_lite.html style.css lib/g6.min.js lib/exceljs.min.js ../templates/GLL_template.xlsx",
    "inject-excel-template": "node src/package/inject_excel_template.mjs",
    "substitute-gll": "node src/package/substitute_gll_bundle_reference.js",
    "dist": "npm run clean && npm run bundle && npm run inject-excel-template && npm run substitute-gll start && (npm run create-gll-zip && npm run create-inline-html && electron-builder --linux --win; npm run substitute-gll end) || npm run substitute-gll end",
    "serve": "npx http-server src -p 8000 --cors"
  },
  "build": {
    "appId": "com.delta4ai.graphlenslite",
    "productName": "Graph Lens Lite",
    "icon": "static/delta-4-icon.png",
    "files": [
      "src/**/*",
      "static/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Graphics",
      "maintainer": "Delta 4 GmbH <office@delta4.ai>"
    }
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.11",
    "exceljs": "^4.4.0",
    "inline-source": "^8.0.3",
    "inline-source-cli": "^1.2.0",
    "rimraf": "^6.0.1"
  }
}
