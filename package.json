{
  "name": "graph-lens-lite",
  "version": "1.0.3",
  "main": "src/package/electron_app.js",
  "description": "Visualise and explore property graphs in a lightweight desktop app.",
  "homepage": "https://github.com/Delta4AI/GraphLensLite",
  "author": {
    "name": "Matthias Ley",
    "email": "matthias.ley@delta4.ai"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "clean": "rimraf dist && mkdir -p dist",
    "create-inline-html": "node src/package/inline_html.js src/graph_lens_lite.html dist/graph-lens-lite_${npm_package_version}.html",
    "create-gll-zip": "cd src && zip -r ../dist/GLL-source-bundle_${npm_package_version}.zip lib/g6.min.js gll.js graph_lens_lite.html lib/xlsx.full.min.js ../templates/GLL_template.xlsx",
    "dist": "npm run clean && npm run create-gll-zip && npm run create-inline-html && electron-builder --linux --win"
  },
  "build": {
    "appId": "com.delta4ai.graphlenslite",
    "productName": "Graph Lens Lite",
    "icon": "static/delta-4-icon.png",
    "files": [
      "src/**/*",
      "static/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "snap"
      ],
      "category": "Graphics",
      "maintainer": "Delta 4 GmbH <office@delta4.ai>"
    }
  },
  "devDependencies": {
    "electron": "^36.3.1",
    "electron-builder": "^26.0.12",
    "inline-source": "^8.0.3",
    "inline-source-cli": "^2.0.0",
    "rimraf": "^6.0.1"
  }
}
