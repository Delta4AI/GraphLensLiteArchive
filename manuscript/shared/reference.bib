@article{brownNAViGaTORNetworkAnalysis2009,
  title = {{{NAViGaTOR}}: {{Network Analysis}}, {{Visualization}} and {{Graphing Toronto}}},
  shorttitle = {{{NAViGaTOR}}},
  author = {Brown, Kevin R. and Otasek, David and Ali, Muhammad and McGuffin, Michael J. and Xie, Wing and Devani, Baiju and van Toch, Ian Lawson and Jurisica, Igor},
